{
  "name": "lilpos-register-mock",
  "version": "1.0.0",
  "private": true,
  "scripts": {
  "dev": "npm run build && npx --yes http-server . -p 8001 -c-1",
  "typecheck": "tsc -p tsconfig.json --noEmit",
  "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'); fs.copyFileSync('dist/sw.js','sw.js'); fs.copyFileSync('dist/sw.js.map','sw.js.map'); fs.rmSync('public',{recursive:true,force:true}); fs.mkdirSync('public/dist',{recursive:true}); fs.cpSync('dist','public/dist',{recursive:true}); fs.cpSync('icons','public/icons',{recursive:true}); ['index.html','styles.css','manifest.webmanifest','sw.js','sw.js.map'].forEach(f=>fs.copyFileSync(f,'public/'+f));\"",
  "cf:dev": "npm run build && wrangler dev",
  "cf:deploy": "npm run build && wrangler deploy"
},
  "devDependencies": {
    "typescript": "^5.8.3",
    "wrangler": "^4.107.1"
  }
}
