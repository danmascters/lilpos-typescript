{
  "name": "lilpos-register-mock",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run build && npx --yes http-server . -p 5173 -c-1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('dist/sw.js','sw.js'); require('fs').copyFileSync('dist/sw.js.map','sw.js.map')\"",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "wrangler": "^4.107.1"
  }
}
